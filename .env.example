# N8N Webhook Configuration
# Copy file ini ke .env.local dan sesuaikan nilai sesuai kebutuhan

# ============================================================================
# JAVASCRIPT/REACT CONFIGURATION
# ============================================================================

# Base URL untuk API PHP. Biarkan kosong jika ingin pakai fallback bawaan.
# Contoh:
VITE_API_BASE=http://localhost:8000
VITE_API_BASE=http://localhost/netreport/api

VITE_API_BASE=http://localhost:8000

# N8N Webhook URL untuk menerima data analisis WiFi (JavaScript)
# Default: http://localhost:5678/webhook-test/Laptop-diagnose
# VITE_N8N_WEBHOOK_URL=http://localhost:5678/webhook-test/Laptop-diagnose

# Untuk Production, gunakan URL yang sesuai:
# VITE_N8N_WEBHOOK_URL=https://your-n8n-domain.com/webhook-test/Laptop-diagnose

# ============================================================================
# PHP CONFIGURATION
# ============================================================================

# N8N Webhook URL untuk PHP (bisa berbeda dari JS atau sama)
# Default: http://localhost:5678/webhook-test/netreport
N8N_WEBHOOK_URL=http://localhost:5678/webhook-test/netreport

# Webhook timeout in seconds
N8N_WEBHOOK_TIMEOUT=30

# Enable debug mode (set to false for production)
N8N_WEBHOOK_DEBUG=true

# Enable logging to file
N8N_WEBHOOK_LOG_TO_FILE=false

# Log file path (buat folder logs terlebih dahulu)
# N8N_WEBHOOK_LOG_PATH=/path/to/logs/webhook.log

# Retry configuration
N8N_WEBHOOK_RETRY=true
N8N_WEBHOOK_MAX_RETRIES=3
N8N_WEBHOOK_RETRY_DELAY=1000  # milliseconds
