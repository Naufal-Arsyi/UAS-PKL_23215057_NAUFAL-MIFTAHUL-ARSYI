# N8N Webhook Configuration
# Copy file ini ke .env.local dan sesuaikan nilai sesuai kebutuhan

# N8N Webhook URL untuk menerima data analisis WiFi
# Default: http://localhost:5678/webhook-test/Laptop-diagnose
VITE_N8N_WEBHOOK_URL=http://localhost:5678/webhook-test/Laptop-diagnose

# Untuk Production, gunakan URL yang sesuai:
# VITE_N8N_WEBHOOK_URL=https://your-n8n-domain.com/webhook-test/Laptop-diagnose
